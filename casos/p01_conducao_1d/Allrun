#!/bin/sh
# MCFT — Prática 1: Condução 1D estacionária
cd ${0%/*} || exit 1

. ${WM_PROJECT_DIR:?}/bin/tools/RunFunctions

echo "========================================"
echo "  MCFT P1 — Condução 1D Estacionária"
echo "========================================"

# 1. Gerar malha
runApplication blockMesh

# 2. Correr solver
runApplication laplacianFoam

# 3. Converter para VTK (visualização no ParaView)
runApplication foamToVTK

echo ""
echo "========================================"
echo "  Concluído!"
echo ""
echo "  Solução esperada (Exercise 2.1):"
echo "    T1 = 137.5 °C  (x = 0.0375 m)"
echo "    T2 = 112.5 °C  (x = 0.1125 m)"
echo "    T3 =  87.5 °C  (x = 0.1875 m)"
echo "    T4 =  62.5 °C  (x = 0.2625 m)"
echo ""
echo "  Para visualizar:"
echo "    1. Descarrega esta pasta (botão direito no VS Code → Download)"
echo "    2. Abre o ParaView no teu PC"
echo "    3. File → Open → selecciona VTK/p01_.../p01_..._.vtm"
echo "========================================"
