/*
  Monitoriza T no centro do domínio (0.5, 0.5, 0.005)
  Usado para extrapolação de Richardson.
*/
FoamFile { version 2.0; format ascii; class dictionary; object probeDict; }
type    probes;
libs    (sampling);
writeControl    timeStep;
writeInterval   1;
probeLocations  ( (0.5 0.5 0.005) );
fields          ( T );
