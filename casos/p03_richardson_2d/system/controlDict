FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }
application     laplacianFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         10;        // estado estacionário atingido rapidamente (DT=1, L=1)
deltaT          0.1;
writeControl    timeStep;
writeInterval   100;       // guarda só o estado final
purgeWrite      1;
writeFormat     ascii;
writePrecision  10;        // precisão alta para Richardson
runTimeModifiable true;
